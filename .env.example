# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
#
# See docs/API_SETUP_GUIDE.md for detailed setup instructions

# ============================================================
# SUPABASE (Required) - Backend & Database
# ============================================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ACCESS_TOKEN=your-supabase-access-token-here
DATABASE_URL=https://your-project.supabase.co

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:9002

# Vercel environment metadata (set automatically in Vercel, optional locally)
# VERCEL_ENV=development           # or "preview" | "production"
# VERCEL_URL=taskmvp-wo1w.vercel.app

# ============================================================
# PAYTRAIL (Required for Payments) - Finnish Payment Gateway
# ============================================================
# Test credentials (default - works out of the box in test environment):
PAYTRAIL_MERCHANT_ID=375917
PAYTRAIL_SECRET_KEY=SAIPPUAKAUPPIAS

# Enable mock mode to skip real Paytrail calls (useful locally / in preview)
# When true, payments are "auto-approved" and user is redirected back to app
PAYTRAIL_MOCK=true

# For production, get real credentials from: https://www.paytrail.com
# PAYTRAIL_MERCHANT_ID=your-production-merchant-id
# PAYTRAIL_SECRET_KEY=your-production-secret-key

# ============================================================
# GOOGLE MAPS API (Required) - Location & Address Search
# ============================================================
# Get from: https://console.cloud.google.com/google/maps-apis
# Required APIs: Places API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================
# OPTIONAL SERVICES (Not required for basic development)
# ============================================================

# GitHub Integration (only needed for AI development tools)
# GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat
# GITHUB_TOKEN=your-github-token

# Add to supabase/.env for google auth

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
