# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control
#
# See docs/API_SETUP_GUIDE.md for detailed setup instructions

# ============================================================
# SUPABASE (Required) - Backend & Database
# ============================================================
# Get these from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ACCESS_TOKEN=your-supabase-access-token-here
DATABASE_URL=https://your-project.supabase.co

# ============================================================
# APPLICATION CONFIGURATION
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:9002

# ============================================================
# PAYTRAIL (Required for Payments) - Finnish Payment Gateway
# ============================================================
# Test credentials (default - works out of the box):
PAYTRAIL_MERCHANT_ID=375917
PAYTRAIL_SECRET_KEY=SAIPPUAKAUPPIAS
#
# For production, get from: https://www.paytrail.com
# PAYTRAIL_MERCHANT_ID=your-production-merchant-id
# PAYTRAIL_SECRET_KEY=your-production-secret-key

# ============================================================
# GOOGLE MAPS API (Required) - Location & Address Search
# ============================================================
# Get from: https://console.cloud.google.com/google/maps-apis
# Required APIs: Places API, Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================
# OPTIONAL SERVICES (Not required for basic development)
# ============================================================

# GitHub Integration (only needed for AI development tools)
# GITHUB_PERSONAL_ACCESS_TOKEN=your-github-pat
# GITHUB_TOKEN=your-github-token

